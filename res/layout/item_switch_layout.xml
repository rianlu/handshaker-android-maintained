<?xml version="1.0" encoding="utf-8"?>
<merge android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView android:layout_gravity="center_vertical" android:id="@id/item_switch_icon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/item_icon_right_margin" />
    <LinearLayout android:layout_gravity="center_vertical" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/switch_title_size" android:textColor="@color/item_switch_text_colorlist" android:id="@id/item_switch_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="@dimen/switch_title_max_width" android:singleLine="true" />
        <TextView android:textSize="@dimen/item_sub_title_size" android:id="@id/item_switch_summary" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="@dimen/switch_title_max_width" android:singleLine="true" />
    </LinearLayout>
    <LinearLayout android:gravity="right" android:layout_gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <smartisanos.widget.SwitchEx android:id="@id/item_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
</merge>
